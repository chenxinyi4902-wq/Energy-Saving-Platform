from flask import Flask, request

app = Flask(__name__)

energy_records = []

@app.route("/submit-energy", methods=["POST"])
def submit_energy():

    energy = request.form.get("energy")

    if not energy:
        return "No energy data provided"

    try:
        energy_value = float(energy)
    except ValueError:
        return "Invalid energy value"

    energy_records.append(energy_value)

    print("Current records:", energy_records)

    return "Energy recorded successfully"

if __name__ == "__main__":
    app.run(debug=True)
