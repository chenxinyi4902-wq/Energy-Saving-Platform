from flask import Flask, request

app = Flask(__name__)

@app.route("/submit-energy", methods=["POST"])
def submit_energy():

    energy = request.form.get("energy")

    if not energy:
        return "No energy data provided"

    try:
        energy_value = float(energy)
    except ValueError:
        return "Invalid energy value"

    print("Energy received:", energy_value)

    return "Energy data received successfully"

if __name__ == "__main__":
    app.run(debug=True)
